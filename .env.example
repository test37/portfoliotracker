# Copy to .env (gitignored) and fill in real values.

## Image source (only used by stack.yml / production)
GITHUB_OWNER=test37
TAG=latest

## Host port that maps to nginx :80
APP_PORT=8282

## Public hostname (used by Traefik labels only)
PUBLIC_HOST=portfolio.example.com

## Database
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=portfolio_db
MYSQL_USER=portfolio_user
MYSQL_PASSWORD=change-me-user

## API
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
ALPHA_VANTAGE_KEY=

## SMTP (used by mailer for password reset, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=app-password-here
SMTP_FROM=user@example.com
