# Copy this file to `.env` and edit the values.
# `.env` is gitignored and never baked into the image.

# Your GitHub username or org (used for the GHCR image name).
GITHUB_OWNER=your-github-username

# Image tag to pull. Use 'latest' or a commit SHA.
TAG=latest

# Port on the host machine to expose the site on. Container always listens on 8080.
HOST_PORT=8080

# Public hostname (only used when behind Traefik / reverse proxy).
PUBLIC_HOST=portfolio.example.com

# Container timezone.
TZ=UTC
